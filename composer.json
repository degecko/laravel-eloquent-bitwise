{
    "name": "degecko/laravel-eloquent-bitwise",
    "description": "Manage boolean flags and statuses as a fluent collection on Eloquent models",
    "keywords": ["laravel", "eloquent", "bitwise", "flags", "status", "collection"],
    "license": "MIT",
    "authors": [
        {
            "name": "Cosmin Gheorghita",
            "email": "gecko.alpad@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "DeGecko\\Bitwise\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DeGecko\\Bitwise\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable"
}